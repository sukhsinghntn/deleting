@page "/myforms"
@using System.Net.Http.Json
@using DynamicFormsApp.Shared.Models
@using DynamicFormsApp.Client.Pages.DynamicForms
@inject HttpClient Http
@inject NavigationManager Navigation
@inject CookieHelper CookieHelper
@inject IJSRuntime JS

<h3 class="mb-3">My Forms</h3>

@if (forms == null)
{
    <p>Loading...</p>
}
else if (!forms.Any())
{
    <p>You haven't created any forms yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in forms)
                {
                    <tr>
                        <td>
                            @f.Name
                            @if (!f.IsActive)
                            {
                                <span class="badge bg-secondary ms-2">Inactive</span>
                            }
                        </td>
                        <td>@f.Description</td>
                        <td>
                            <a class="btn btn-sm btn-primary me-2" href="@($"/forms/{f.Id}")">Open</a>
                            <a class="btn btn-sm btn-secondary me-2" href="@($"/forms/{f.Id}/edit")">Edit</a>
                            <a class="btn btn-sm btn-secondary me-2" href="@($"/forms/{f.Id}/responses")">Responses</a>
                            <a class="btn btn-sm btn-info me-2" href="@($"/forms/{f.Id}/summary")">Summary</a>
                            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => ShareForm(f.Id)">Share</button>
                            @if (f.PreviousVersionId != null)
                            {
                                <a class="btn btn-sm btn-outline-secondary me-2" href="@($"/forms/{f.Id}/history")">History</a>
                            }
                            @if (f.IsActive)
                            {
                                <button class="btn btn-sm btn-danger" @onclick="() => UnpublishForm(f.Id)">Unpublish</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => PublishForm(f.Id)">Publish</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Form>? forms;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var user = await CookieHelper.LoginStatus();
            if (string.IsNullOrEmpty(user))
            {
                var ret = Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri));
                Navigation.NavigateTo($"login?returnUrl={ret}", true);
                return;
            }

            forms = await Http.GetFromJsonAsync<List<Form>>("api/forms/mine");
            StateHasChanged();
        }
    }

    private async Task UnpublishForm(int id)
    {
        var item = forms?.FirstOrDefault(f => f.Id == id);
        if (item == null)
        {
            return;
        }

        bool? confirmed = await DialogService.Confirm(
            "Unpublish this form?",
            "Unpublish Form",
            new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });

        if (confirmed != true)
        {
            return;
        }

        await Http.DeleteAsync($"api/forms/{id}");
        item.IsActive = false;
        NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Form Unpublished",
                Detail = item.Name
            });
        StateHasChanged();
    }

    private async Task PublishForm(int id)
    {
        var item = forms?.FirstOrDefault(f => f.Id == id);
        if (item == null)
            return;

        bool? confirmed = await DialogService.Confirm(
            "Publish this form?",
            "Publish Form",
            new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });

        if (confirmed != true)
            return;

        await Http.PostAsync($"api/forms/{id}/publish", null);
        item.IsActive = true;
        NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Form Published",
                Detail = item.Name
            });
        StateHasChanged();
    }

    private async Task ShareForm(int id)
    {
        var parameters = new Dictionary<string, object>
        {
            ["FormId"] = id
        };

        await DialogService.OpenAsync<ShareFormDialog>("Share Form", parameters,
            new DialogOptions { Width = "500px" });
    }
}
